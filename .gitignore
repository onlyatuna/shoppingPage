# --- 基礎依賴與環境 (你原本有的) ---
node_modules
.env
.env.*.local
.DS_Store

# --- 編譯產出 (Build Outputs) ---
dist
dist-ssr
build
*.tsbuildinfo
*.sql

# --- Log 與除錯檔案 (這是你目前最需要補上的) ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 針對你專案中特定的雜訊檔案 ---
debug_log.json
debug_output.txt
test_output.txt
test_result.json
test-monitoring.ts

# --- 編輯器設定  ---
.vscode
.idea
*.suo
*.ntvs
*.njsproj
*.sln
*.sw?

# Windows 檔案串流垃圾檔
*:Zone.Identifier

# --- AI Agent 工具目錄 ---
.agent/
.agents/
tasks/

